# =============================================================================
# LifePlanner — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# PostgreSQL
POSTGRES_USER=lifeplanner
POSTGRES_PASSWORD=lifeplanner_secret_change_me
POSTGRES_DB=lifeplanner

# Database URL (used by Prisma — adjust if running backend directly)
DATABASE_URL=postgresql://lifeplanner:lifeplanner_secret_change_me@localhost:5432/lifeplanner

# JWT Secrets — CHANGE THESE in production!
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_please_change_me
JWT_REFRESH_SECRET=your_refresh_token_secret_also_change_this_one

# Backend
PORT=3001
NODE_ENV=development

# Frontend URL (used by backend for CORS)
FRONTEND_URL=http://localhost:5173

# Frontend (Vite) — prefix with VITE_ to expose to browser
# In development with Vite proxy, you can leave this as /api
# In production or Docker, set to full URL: http://your-server:3001/api
VITE_API_URL=/api
