generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  username       String          @unique
  passwordHash   String
  createdAt      DateTime        @default(now())
  icalToken               String?         @unique

  // Google Calendar OAuth
  googleAccessToken       String?
  googleRefreshToken      String?
  googleTokenExpiry       DateTime?
  googleCalendarId        String?
  googleLastSync          DateTime?

  notes          Note[]
  events         Event[]
  todos          Todo[]
  todoLists      TodoList[]
  coffeeSessions CoffeeSession[]
  preferences    UserPreferences?
}

model UserPreferences {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Theme
  themeName String @default("terracotta")

  // Core palette
  colorBackground    String @default("#FFF8F0")
  colorPrimary       String @default("#E8825A")
  colorPrimaryDark   String @default("#C4614A")
  colorSecondary     String @default("#F5A623")
  colorSurface       String @default("#FFFFFF")
  colorSurfaceElev   String @default("#FFF3E8")
  colorTextPrimary   String @default("#3D2B1F")
  colorTextSecondary String @default("#8B6355")
  colorTextMuted     String @default("#B89080")
  colorBorder        String @default("#E8D5C4")
  colorSuccess       String @default("#6BAF7A")
  colorAccent        String @default("#9B7FA6")

  // Typography
  fontFamily String @default("inter")
  fontSize   String @default("md")

  // Layout density
  density String @default("comfortable")

  // Feature defaults
  defaultCalendarView String @default("month")
  coffeeWorkMins      Int    @default(30)
  coffeeBreakMins     Int    @default(5)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CoffeeSession {
  id           String   @id @default(cuid())
  label        String
  completedAt  DateTime @default(now())
  durationMins Int      @default(30)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, completedAt])
}

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String
  color     String   @default("#FFF3E8")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Event {
  id            String    @id @default(cuid())
  title         String
  description   String?
  startTime     DateTime
  endTime       DateTime?
  allDay        Boolean   @default(false)
  color         String    @default("#E8825A")

  // Recurring events
  rrule         String?
  recurrenceId  String?
  parentEventId String?
  parentEvent   Event?    @relation("RecurringChildren", fields: [parentEventId], references: [id], onDelete: Cascade)
  childEvents   Event[]   @relation("RecurringChildren")

  // iCal sync
  icalUid       String?   @unique

  // Reminders
  reminderMinutes Int?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startTime])
  @@index([userId, icalUid])
}

model TodoList {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  todos     Todo[]

  @@index([userId])
}

model Todo {
  id          String    @id @default(cuid())
  text        String
  completed   Boolean   @default(false)
  completedAt DateTime?
  priority    String    @default("medium")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  listId      String?
  list        TodoList? @relation(fields: [listId], references: [id], onDelete: SetNull)

  @@index([userId, completed])
  @@index([listId])
}
